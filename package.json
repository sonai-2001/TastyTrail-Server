    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/mongoose": "^5.11.97",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.0",
    "@types/nodemailer": "^7.0.2",
    "@types/validator": "^13.15.3",
    "eslint": "^8.50.0",
    "express-list-endpoints": "^7.1.1",
    "husky": "^8.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.0"
  }
